    "db:seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "cloudinary": "^2.5.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "sequelize": "^6.37.8",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.5"
  }
}
