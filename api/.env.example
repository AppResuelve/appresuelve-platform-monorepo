# Database
DATABASE_URL=postgresql://localhost:5432/appresuelve_onboarding

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Frontend URLs
ONBOARDING_URL=http://localhost:5173

# Storage
STORAGE_PROVIDER=local

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production (uncomment for prod)
# STORAGE_PROVIDER=cloudinary
# ONBOARDING_URL=https://onboarding.appresuelve.site
# CORS_ORIGINS=https://onboarding.appresuelve.site,https://admin.appresuelve.site,https://appresuelve.site
# NODE_ENV=production
