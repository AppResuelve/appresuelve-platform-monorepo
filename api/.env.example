# Database
DATABASE_URL=postgresql://localhost:5432/appresuelve_onboarding

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Frontend URLs
ONBOARDING_URL=http://localhost:5173

# Storage

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production (uncomment for prod)
# ONBOARDING_URL=https://onboarding.appresuelve.site
# CORS_ORIGINS=https://onboarding.appresuelve.site,https://admin.appresuelve.site,https://appresuelve.site
# NODE_ENV=production

# Auth
JWT_SECRET=cambiar-por-secreto-seguro
PLATFORM_ADMIN_EMAIL=admin@appresuelve.com
PLATFORM_ADMIN_PASSWORD=

# Client API secret
APPRESUELVE_SECRET=
